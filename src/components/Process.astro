---
interface Step {
  command: string;
  output: string;
  color: string;
}

const steps: Step[] = [
  {
    command: "analyze --requirements",
    output: "Écoute active du besoin client · User stories · Cahier des charges",
    color: "var(--green)",
  },
  {
    command: "architect --design",
    output: "Modélisation UML/Merise · Choix de stack · Base de données",
    color: "var(--purple)",
  },
  {
    command: "dev --build",
    output: "Next.js · React · TypeScript · Clean code · Tests unitaires",
    color: "var(--accent)",
  },
  {
    command: "test --deploy",
    output: "CI/CD GitHub Actions · Docker · VPS OVH · Monitoring",
    color: "var(--amber)",
  },
  {
    command: "maintain --iterate",
    output: "Feedback utilisateur · Métriques · Amélioration continue",
    color: "var(--green)",
  },
];
---

<section id="process">
  <h2 class="section-title">Comment je travaille</h2>

  <div class="terminal-wrapper fade-up">
    <div class="terminal" id="terminal">
      <!-- Title bar -->
      <div class="terminal-bar">
        <div class="terminal-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="terminal-title">christophe@dev ~ %</span>
        <div class="terminal-bar-spacer"></div>
      </div>

      <!-- Terminal body -->
      <div class="terminal-body" id="terminalBody">
        {steps.map((step, i) => (
          <div class="term-block" data-index={i} data-command={step.command} data-output={step.output} data-color={step.color}>
            <div class="term-line">
              <span class="term-prompt" style={`color: ${step.color}`}>$</span>
              <span class="term-command"></span>
              <span class="term-cursor">_</span>
            </div>
            <div class="term-output"></div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="metrics fade-up">
    <div class="metric-pill">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      <span>5+ projets livrés</span>
    </div>
    <div class="metric-pill">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 10 3 12 0v-5"/></svg>
      <span>Formation Bac+4</span>
    </div>
    <div class="metric-pill">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>
      <span>Spé. IA & SaaS</span>
    </div>
  </div>
</section>

<style>
  #process {
    padding: 5rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* === TERMINAL WRAPPER === */
  .terminal-wrapper {
    max-width: 800px;
    margin: 0 auto 2.5rem;
  }

  .terminal {
    background: #0c0c0e;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.03),
      0 8px 40px rgba(0, 0, 0, 0.5),
      0 0 80px rgba(59, 130, 246, 0.04);
  }

  /* === TITLE BAR === */
  .terminal-bar {
    display: flex;
    align-items: center;
    padding: 0.875rem 1.25rem;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--border);
  }

  .terminal-dots {
    display: flex;
    gap: 7px;
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
    user-select: none;
  }

  .terminal-bar-spacer {
    width: 52px; /* balance the dots on the left */
  }

  /* === TERMINAL BODY === */
  .terminal-body {
    padding: 1.5rem 1.5rem 1.75rem;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .term-block {
    opacity: 0;
    transform: translateY(6px);
  }
  .term-block.active,
  .term-block.done {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .term-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .term-prompt {
    font-weight: 700;
    flex-shrink: 0;
  }

  .term-command {
    color: var(--text);
    white-space: pre;
  }

  .term-cursor {
    display: inline-block;
    color: var(--text);
    font-weight: 300;
    animation: cursorBlink 0.9s step-end infinite;
  }
  .term-cursor.hidden {
    display: none;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .term-output {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding-left: 1.25rem;
    margin-top: 0.25rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    line-height: 1.6;
  }
  .term-output.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* === METRICS === */
  .metrics {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .metric-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    transition: border-color var(--transition), color var(--transition);
  }
  .metric-pill:hover {
    border-color: var(--border-light);
    color: var(--text);
  }
  .metric-pill svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* === RESPONSIVE === */
  @media (max-width: 640px) {
    .terminal-body {
      padding: 1.125rem 1rem 1.375rem;
      min-height: 240px;
      gap: 1rem;
    }

    .term-line {
      font-size: 0.8125rem;
    }

    .term-output {
      font-size: 0.75rem;
      padding-left: 1rem;
    }

    .terminal-bar {
      padding: 0.75rem 1rem;
    }

    .terminal-title {
      font-size: 0.6875rem;
    }

    .dot {
      width: 9px;
      height: 9px;
    }

    .terminal-bar-spacer {
      width: 40px;
    }

    .metrics {
      gap: 0.5rem;
    }

    .metric-pill {
      font-size: 0.75rem;
      padding: 0.4rem 0.75rem;
    }
  }
</style>

<script>
  const terminal = document.getElementById("terminal");
  if (terminal) {
    const blocks = terminal.querySelectorAll<HTMLDivElement>(".term-block");
    let hasPlayed = false;

    async function sleep(ms: number): Promise<void> {
      return new Promise((r) => setTimeout(r, ms));
    }

    async function typeCommand(block: HTMLDivElement): Promise<void> {
      const command = block.dataset.command || "";
      const output = block.dataset.output || "";
      const commandEl = block.querySelector<HTMLSpanElement>(".term-command")!;
      const outputEl = block.querySelector<HTMLDivElement>(".term-output")!;
      const cursorEl = block.querySelector<HTMLSpanElement>(".term-cursor")!;

      // Show block
      block.classList.add("active");
      cursorEl.classList.remove("hidden");

      // Type command char by char
      for (let i = 0; i < command.length; i++) {
        commandEl.textContent += command[i];
        await sleep(38);
      }

      // Pause then show output
      await sleep(300);
      cursorEl.classList.add("hidden");
      outputEl.textContent = output;
      outputEl.classList.add("visible");

      block.classList.remove("active");
      block.classList.add("done");
    }

    async function playSequence(): Promise<void> {
      if (hasPlayed) return;
      hasPlayed = true;

      for (let i = 0; i < blocks.length; i++) {
        await typeCommand(blocks[i]);
        if (i < blocks.length - 1) {
          await sleep(400);
        }
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasPlayed) {
            playSequence();
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(terminal);
  }
</script>
