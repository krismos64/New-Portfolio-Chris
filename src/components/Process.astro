---
interface Step {
  command: string;
  comment?: string;
  outputs: string[];
  color: string;
}

const steps: Step[] = [
  {
    command: "analyze --deep --no-bullshit",
    comment: "# Pas de code sans comprendre le pourquoi",
    outputs: [
      "Benchmark concurrentiel · Analyse SWOT · Analyse des risques",
      "Besoins fonctionnels & non fonctionnels · User stories",
      "Cahier des charges · Contraintes RGPD · Objectifs SEO",
    ],
    color: "var(--green)",
  },
  {
    command: "architect --blueprint --think-twice",
    comment: "# Mesurer deux fois, couper une fois",
    outputs: [
      "Maquettage Figma · Parcours utilisateur · Design system",
      "MCD / MLD (JMerise) · Diagrammes UML · Schéma d'architecture",
      "Choix de stack adapté au projet · ORM Prisma ou alternative",
    ],
    color: "var(--purple)",
  },
  {
    command: "dev --build --clean-code --tests",
    comment: "# Le code, c'est de la poésie... avec des points-virgules",
    outputs: [
      "Next.js · React · TypeScript strict · Node.js · API REST",
      "PostgreSQL / MySQL / MongoDB — selon le projet, pas le dogme",
      "Vitest (unit) · Playwright (E2E) · Cahier de recettage",
    ],
    color: "var(--accent)",
  },
  {
    command: "deploy --devops --sleep-well",
    comment: "# Un bon déploiement = une bonne nuit de sommeil",
    outputs: [
      "Docker · CI/CD GitHub Actions · VPS OVH · Monitoring",
      "SEO technique · Performance Lighthouse · Accessibilité",
      "Git flow · Versionning rigoureux · Zero downtime",
    ],
    color: "var(--amber)",
  },
  {
    command: "manage --agile --document-everything",
    comment: "# La doc, c'est le message qu'on s'envoie au futur",
    outputs: [
      "Scrum / méthode Agile · Sprints · Daily · Rétrospectives",
      "Jira (tickets, backlog, sprints) · Confluence (documentation)",
      "Feedback utilisateur · Métriques · Amélioration continue",
    ],
    color: "var(--green)",
  },
];
---

<section id="process">
  <h2 class="section-title">Comment je travaille</h2>
  <p class="section-subtitle">Mon workflow, de l'idée au déploiement — sans raccourci.</p>

  <div class="terminal-wrapper fade-up">
    <div class="terminal" id="terminal">
      <!-- Title bar -->
      <div class="terminal-bar">
        <div class="terminal-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="terminal-title">christophe@dev ~/workflow %</span>
        <div class="terminal-bar-spacer"></div>
      </div>

      <!-- Terminal body -->
      <div class="terminal-body" id="terminalBody">
        {steps.map((step, i) => (
          <div
            class="term-block"
            data-index={i}
            data-command={step.command}
            data-comment={step.comment || ""}
            data-outputs={JSON.stringify(step.outputs)}
            data-color={step.color}
          >
            {step.comment && (
              <div class="term-comment"></div>
            )}
            <div class="term-line">
              <span class="term-prompt" style={`color: ${step.color}`}>$</span>
              <span class="term-command"></span>
              <span class="term-cursor">_</span>
            </div>
            <div class="term-outputs"></div>
          </div>
        ))}
        <div class="term-block term-final" data-index="final">
          <div class="term-line">
            <span class="term-prompt" style="color: var(--green)">$</span>
            <span class="term-command"></span>
            <span class="term-cursor">_</span>
          </div>
          <div class="term-final-output"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="metrics fade-up">
    <div class="metric-pill">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      <span>5+ projets livrés</span>
    </div>
    <div class="metric-pill">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 10 3 12 0v-5"/></svg>
      <span>Bac+4 Concepteur Dev</span>
    </div>
    <div class="metric-pill">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>
      <span>Spé. IA & SaaS</span>
    </div>
    <div class="metric-pill">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      <span>Adapte la stack au projet</span>
    </div>
  </div>
</section>

<style>
  #process {
    padding: 5rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-muted);
    font-size: 1rem;
    margin-top: -2rem;
    margin-bottom: 2.5rem;
  }

  /* === TERMINAL WRAPPER === */
  .terminal-wrapper {
    max-width: 820px;
    margin: 0 auto 2.5rem;
  }

  .terminal {
    background: #0c0c0e;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.03),
      0 8px 40px rgba(0, 0, 0, 0.5),
      0 0 80px rgba(59, 130, 246, 0.04);
  }

  /* === TITLE BAR === */
  .terminal-bar {
    display: flex;
    align-items: center;
    padding: 0.875rem 1.25rem;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--border);
  }

  .terminal-dots {
    display: flex;
    gap: 7px;
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
    user-select: none;
  }

  .terminal-bar-spacer {
    width: 52px;
  }

  /* === TERMINAL BODY === */
  .terminal-body {
    padding: 1.5rem 1.5rem 1.75rem;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .term-block {
    opacity: 0;
    transform: translateY(6px);
  }
  .term-block.active,
  .term-block.done {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Comment line (# ...) */
  .term-comment {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
    opacity: 0.5;
    font-style: italic;
    margin-bottom: 0.2rem;
    line-height: 1.5;
  }

  .term-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .term-prompt {
    font-weight: 700;
    flex-shrink: 0;
  }

  .term-command {
    color: var(--text);
    white-space: pre;
  }

  .term-cursor {
    display: inline-block;
    color: var(--text);
    font-weight: 300;
    animation: cursorBlink 0.9s step-end infinite;
  }
  .term-cursor.hidden {
    display: none;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Output lines */
  .term-outputs {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    padding-left: 1.25rem;
    margin-top: 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    line-height: 1.6;
  }

  .term-output-line {
    color: var(--text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .term-output-line.visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Prefix arrow for output lines */
  .term-output-line::before {
    content: "→ ";
    color: var(--border-light);
  }

  /* Final success message */
  .term-final {
    margin-top: 0.375rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .term-final-output {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--green);
    padding-left: 1.25rem;
    margin-top: 0.375rem;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .term-final-output.visible {
    opacity: 1;
  }

  /* === METRICS === */
  .metrics {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .metric-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    transition: border-color var(--transition), color var(--transition);
  }
  .metric-pill:hover {
    border-color: var(--border-light);
    color: var(--text);
  }
  .metric-pill svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* === RESPONSIVE === */
  @media (max-width: 640px) {
    .section-subtitle {
      font-size: 0.875rem;
      margin-top: -1.5rem;
      margin-bottom: 2rem;
    }

    .terminal-body {
      padding: 1.125rem 1rem 1.375rem;
      min-height: 280px;
      gap: 0.875rem;
    }

    .term-line {
      font-size: 0.75rem;
    }

    .term-comment {
      font-size: 0.6875rem;
    }

    .term-outputs {
      font-size: 0.6875rem;
      padding-left: 1rem;
    }

    .term-final-output {
      font-size: 0.75rem;
      padding-left: 1rem;
    }

    .terminal-bar {
      padding: 0.75rem 1rem;
    }

    .terminal-title {
      font-size: 0.6875rem;
    }

    .dot {
      width: 9px;
      height: 9px;
    }

    .terminal-bar-spacer {
      width: 40px;
    }

    .metrics {
      gap: 0.5rem;
    }

    .metric-pill {
      font-size: 0.75rem;
      padding: 0.4rem 0.75rem;
    }
  }
</style>

<script>
  const terminal = document.getElementById("terminal");
  if (terminal) {
    const blocks = terminal.querySelectorAll<HTMLDivElement>(".term-block:not(.term-final)");
    const finalBlock = terminal.querySelector<HTMLDivElement>(".term-final");
    let hasPlayed = false;

    async function sleep(ms: number): Promise<void> {
      return new Promise((r) => setTimeout(r, ms));
    }

    async function typeText(el: HTMLSpanElement, text: string, speed: number): Promise<void> {
      for (let i = 0; i < text.length; i++) {
        el.textContent += text[i];
        await sleep(speed);
      }
    }

    async function typeCommand(block: HTMLDivElement): Promise<void> {
      const command = block.dataset.command || "";
      const comment = block.dataset.comment || "";
      const outputs: string[] = JSON.parse(block.dataset.outputs || "[]");
      const commentEl = block.querySelector<HTMLDivElement>(".term-comment");
      const commandEl = block.querySelector<HTMLSpanElement>(".term-command")!;
      const outputsEl = block.querySelector<HTMLDivElement>(".term-outputs")!;
      const cursorEl = block.querySelector<HTMLSpanElement>(".term-cursor")!;

      // Show block
      block.classList.add("active");

      // Show comment first (instant)
      if (commentEl && comment) {
        commentEl.textContent = comment;
      }

      // Type command
      cursorEl.classList.remove("hidden");
      await typeText(commandEl, command, 32);

      // Show outputs line by line
      await sleep(250);
      cursorEl.classList.add("hidden");

      for (let i = 0; i < outputs.length; i++) {
        const line = document.createElement("div");
        line.className = "term-output-line";
        line.textContent = outputs[i];
        outputsEl.appendChild(line);
        await sleep(80);
        line.classList.add("visible");
      }

      block.classList.remove("active");
      block.classList.add("done");
    }

    async function playFinal(): Promise<void> {
      if (!finalBlock) return;
      const commandEl = finalBlock.querySelector<HTMLSpanElement>(".term-command")!;
      const cursorEl = finalBlock.querySelector<HTMLSpanElement>(".term-cursor")!;
      const outputEl = finalBlock.querySelector<HTMLDivElement>(".term-final-output")!;

      finalBlock.classList.add("active");
      cursorEl.classList.remove("hidden");

      await typeText(commandEl, "echo \"Prêt à collaborer ?\"", 32);

      await sleep(350);
      cursorEl.classList.add("hidden");
      outputEl.textContent = "✓ Workflow complet. Zéro étape sautée. Contactez-moi.";
      outputEl.classList.add("visible");

      finalBlock.classList.remove("active");
      finalBlock.classList.add("done");
    }

    async function playSequence(): Promise<void> {
      if (hasPlayed) return;
      hasPlayed = true;

      for (let i = 0; i < blocks.length; i++) {
        await typeCommand(blocks[i]);
        if (i < blocks.length - 1) {
          await sleep(350);
        }
      }

      await sleep(500);
      await playFinal();
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasPlayed) {
            playSequence();
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );

    observer.observe(terminal);
  }
</script>
