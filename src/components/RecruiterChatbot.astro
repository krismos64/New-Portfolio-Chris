<div class="recruiter-chat" data-chatbot>
  <button class="recruiter-chat__launcher" type="button" aria-label="Ouvrir l'assistant IA" aria-expanded="false" data-chat-open>
    <span class="recruiter-chat__launcher-copy">
      <span class="recruiter-chat__launcher-label">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.9 5.1L5 10l5.1 1.9L12 17l1.9-5.1L19 10l-5.1-1.9Z"/><path d="m5 3-.6 1.4L3 5l1.4.6L5 7l.6-1.4L7 5l-1.4-.6Z"/></svg>
        Assistant IA
      </span>
      <strong>Vous recrutez ?</strong>
      <small>Interrogez mon profil technique</small>
    </span>
    <span class="recruiter-chat__launcher-icon" aria-hidden="true">
      <span class="recruiter-chat__status"></span>
      <svg width="27" height="27" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>
    </span>
  </button>

  <section class="recruiter-chat__panel" role="dialog" aria-modal="false" aria-labelledby="recruiter-chat-title" hidden data-chat-panel>
    <header class="recruiter-chat__header">
      <div>
        <p class="recruiter-chat__eyebrow">Assistant Mistral</p>
        <h2 id="recruiter-chat-title">Explorez mon profil technique</h2>
      </div>
      <button class="recruiter-chat__close" type="button" aria-label="Fermer l'assistant" data-chat-close>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </header>

    <div class="recruiter-chat__messages" aria-live="polite" aria-busy="false" data-chat-messages></div>

    <div class="recruiter-chat__suggestions" data-chat-suggestions>
      <p>Quelques pistes pour commencer</p>
      <div class="recruiter-chat__suggestion-list">
        <button type="button"><span>👋</span> Pourquoi vous recruter ?</button>
        <button type="button"><span>🎯</span> Quel poste recherchez-vous ?</button>
        <button type="button"><span>🚀</span> Quel projet démontre le mieux votre niveau ?</button>
        <button type="button"><span>🏗️</span> Expliquez-moi l'architecture de SmartPlanning</button>
        <button type="button"><span>🧪</span> Quelle est votre stratégie de tests ?</button>
        <button type="button"><span>🤝</span> Quelle expérience avez-vous du travail en équipe ?</button>
        <button type="button"><span>🤖</span> Comment utilisez-vous l'IA pour développer ?</button>
        <button type="button"><span>🔍</span> Parlez-moi d'un problème technique complexe</button>
        <button type="button"><span>📍</span> Quelles sont vos disponibilités et votre mobilité ?</button>
        <button type="button"><span>📈</span> Quels sont vos axes de progression ?</button>
      </div>
    </div>

    <form class="recruiter-chat__form" data-chat-form>
      <label class="sr-only" for="recruiter-chat-input">Votre question sur le profil de Christophe</label>
      <textarea id="recruiter-chat-input" rows="1" maxlength="2000" placeholder="Posez une question sur mon profil..." required data-chat-input></textarea>
      <button type="submit" aria-label="Envoyer la question" data-chat-send>
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </form>
    <p class="recruiter-chat__notice">Réponses générées par IA à partir d'informations rédigées et validées par Christophe.</p>
  </section>
</div>

<script>
  type ChatRole = "user" | "assistant";
  interface ChatMessage { role: ChatRole; content: string }

  const root = document.querySelector<HTMLElement>("[data-chatbot]");
  if (root) {
    const openButton = root.querySelector<HTMLButtonElement>("[data-chat-open]")!;
    const closeButton = root.querySelector<HTMLButtonElement>("[data-chat-close]")!;
    const panel = root.querySelector<HTMLElement>("[data-chat-panel]")!;
    const messagesElement = root.querySelector<HTMLElement>("[data-chat-messages]")!;
    const suggestions = root.querySelector<HTMLElement>("[data-chat-suggestions]")!;
    const form = root.querySelector<HTMLFormElement>("[data-chat-form]")!;
    const input = root.querySelector<HTMLTextAreaElement>("[data-chat-input]")!;
    const sendButton = root.querySelector<HTMLButtonElement>("[data-chat-send]")!;
    const storageKey = "krismos_recruiter_chat_v1";
    let conversation: ChatMessage[] = [];
    let sending = false;

    const escapeHtml = (value: string) => value.replace(/[&<>"']/g, (character) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#039;",
    })[character]!);

    const normalizeTypography = (value: string) => value
      .replace(/\s*[\u2013\u2014]\s*/g, ": ")
      .replace(/:\s*:/g, ":");

    const formatAssistantText = (value: string) => escapeHtml(normalizeTypography(value))
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
      .replace(/^\s*-\s+(.+)$/gm, "<span class=\"chat-list-item\">• $1</span>")
      .replace(/\n{2,}/g, "</p><p>")
      .replace(/\n/g, "<br>");

    const addMessage = (message: ChatMessage, streaming = false) => {
      const item = document.createElement("article");
      item.className = `recruiter-chat__message recruiter-chat__message--${message.role}`;
      if (streaming) item.dataset.streaming = "true";

      const meta = document.createElement("div");
      meta.className = "recruiter-chat__message-meta";
      meta.innerHTML = message.role === "assistant"
        ? '<span class="recruiter-chat__avatar" aria-hidden="true">✦</span><span>Assistant IA</span>'
        : '<span>Votre question</span>';

      const content = document.createElement("div");
      content.className = "recruiter-chat__message-content";
      content.innerHTML = message.role === "assistant"
        ? `<p>${formatAssistantText(message.content)}</p>`
        : escapeHtml(message.content);

      item.append(meta, content);
      messagesElement.appendChild(item);
      messagesElement.scrollTop = messagesElement.scrollHeight;
      return content;
    };

    const saveConversation = () => {
      try { sessionStorage.setItem(storageKey, JSON.stringify(conversation.slice(-20))); } catch { /* stockage indisponible */ }
    };

    const restoreConversation = () => {
      try {
        const saved = JSON.parse(sessionStorage.getItem(storageKey) || "[]");
        if (Array.isArray(saved)) {
          conversation = saved.filter((item): item is ChatMessage =>
            item && ["user", "assistant"].includes(item.role) && typeof item.content === "string"
          ).slice(-20);
        }
      } catch { conversation = []; }
      if (conversation.length === 0) {
        conversation = [{ role: "assistant", content: "Bonjour, je suis l'assistant IA du portfolio de Christophe. Je peux vous aider à évaluer son parcours, ses projets et ses choix techniques." }];
      }
      conversation.forEach((message) => addMessage(message));
    };

    const setOpen = (isOpen: boolean) => {
      panel.hidden = !isOpen;
      openButton.hidden = isOpen;
      openButton.setAttribute("aria-expanded", String(isOpen));
      if (isOpen) window.setTimeout(() => input.focus(), 50);
    };

    const setSending = (isSending: boolean) => {
      sending = isSending;
      input.disabled = isSending;
      sendButton.disabled = isSending;
      messagesElement.setAttribute("aria-busy", String(isSending));
    };

    const consumeSse = async (response: Response, content: HTMLElement) => {
      if (!response.body) throw new Error("Flux indisponible");
      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      let answer = "";
      let displayed = "";
      let streamFinished = false;

      const typewriter = window.setInterval(() => {
        const remaining = answer.length - displayed.length;
        if (remaining <= 0) return;
        const step = remaining > 240 ? 3 : remaining > 80 ? 2 : 1;
        displayed = answer.slice(0, displayed.length + step);
        content.innerHTML = `<p>${formatAssistantText(displayed)}</p>`;
        messagesElement.scrollTop = messagesElement.scrollHeight;
      }, 24);

      const parseLine = (line: string) => {
        if (!line.startsWith("data:")) return;
        const data = line.slice(5).trim();
        if (!data || data === "[DONE]") return;
        try {
          const token = JSON.parse(data).choices?.[0]?.delta?.content;
          if (typeof token === "string") {
            answer += token;
          }
        } catch { /* un événement incomplet reste ignoré */ }
      };

      try {
        while (true) {
          const { value, done } = await reader.read();
          buffer += decoder.decode(value || new Uint8Array(), { stream: !done });
          const lines = buffer.split(/\r?\n/);
          buffer = lines.pop() || "";
          lines.forEach(parseLine);
          if (done) break;
        }
        if (buffer) parseLine(buffer);
        if (!answer.trim()) throw new Error("Réponse vide");
        streamFinished = true;

        await new Promise<void>((resolve) => {
          const waitForTypewriter = window.setInterval(() => {
            if (streamFinished && displayed.length >= answer.length) {
              window.clearInterval(waitForTypewriter);
              resolve();
            }
          }, 25);
        });
      } finally {
        window.clearInterval(typewriter);
      }
      displayed = answer;
      content.innerHTML = `<p>${formatAssistantText(answer)}</p>`;
      return answer.trim();
    };

    const sendQuestion = async (question: string) => {
      const cleanQuestion = question.trim();
      if (!cleanQuestion || sending) return;
      suggestions.hidden = true;
      const userMessage: ChatMessage = { role: "user", content: cleanQuestion };
      conversation.push(userMessage);
      addMessage(userMessage);
      input.value = "";
      input.style.height = "auto";
      setSending(true);

      const assistantContent = addMessage({ role: "assistant", content: "Analyse en cours..." }, true);
      const assistantItem = assistantContent.closest<HTMLElement>(".recruiter-chat__message")!;
      try {
        const response = await fetch("/api/chat.php", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages: conversation.slice(-10) }),
        });
        if (!response.ok) throw new Error(`Proxy HTTP ${response.status}`);
        assistantContent.textContent = "";
        const answer = await consumeSse(response, assistantContent);
        conversation.push({ role: "assistant", content: answer });
        saveConversation();
      } catch (error) {
        console.error("Chatbot Mistral:", error);
        const fallback = "L'assistant est temporairement indisponible. Vous pouvez consulter le CV ou contacter Christophe à christophe.mostefaoui.dev@gmail.com.";
        assistantContent.innerHTML = `<p>${formatAssistantText(fallback)}</p>`;
        conversation.push({ role: "assistant", content: fallback });
        saveConversation();
      } finally {
        delete assistantItem.dataset.streaming;
        setSending(false);
        input.focus();
      }
    };

    restoreConversation();
    openButton.addEventListener("click", () => setOpen(true));
    closeButton.addEventListener("click", () => setOpen(false));
    document.addEventListener("keydown", (event) => { if (event.key === "Escape" && !panel.hidden) setOpen(false); });
    form.addEventListener("submit", (event) => { event.preventDefault(); sendQuestion(input.value); });
    input.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && !event.shiftKey) { event.preventDefault(); sendQuestion(input.value); }
    });
    input.addEventListener("input", () => {
      input.style.height = "auto";
      input.style.height = `${Math.min(input.scrollHeight, 112)}px`;
    });
    suggestions.querySelectorAll<HTMLButtonElement>("button").forEach((button) =>
      button.addEventListener("click", () => sendQuestion(button.textContent || ""))
    );
  }
</script>

<style>
  .recruiter-chat { position: fixed; right: 1.5rem; bottom: 1.5rem; z-index: 100; }
  .recruiter-chat__launcher { position: relative; display: flex; align-items: center; gap: .85rem; min-width: 270px; padding: .7rem .75rem .7rem 1rem; overflow: hidden; color: white; text-align: left; background: linear-gradient(135deg, #172554 0%, var(--accent-btn) 58%, #4f46e5 100%); border: 1px solid rgba(147,197,253,.48); border-radius: 18px; box-shadow: 0 14px 38px rgba(0,0,0,.52), 0 0 30px rgba(59,130,246,.26); cursor: pointer; isolation: isolate; animation: chat-launcher-enter .5s ease-out, chat-attention 7s ease-in-out 2s infinite; transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition); }
  .recruiter-chat__launcher::before { content: ""; position: absolute; z-index: -1; inset: -50% auto -50% -35%; width: 32%; background: linear-gradient(90deg, transparent, rgba(255,255,255,.22), transparent); transform: rotate(16deg); animation: chat-shimmer 7s ease-in-out 3s infinite; }
  .recruiter-chat__launcher:hover { animation: none; transform: translateY(-3px); border-color: rgba(191,219,254,.9); box-shadow: 0 18px 44px rgba(0,0,0,.55), 0 0 38px rgba(59,130,246,.38); }
  .recruiter-chat__launcher:focus-visible, .recruiter-chat button:focus-visible, .recruiter-chat textarea:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .recruiter-chat__launcher-copy { display: flex; flex: 1; flex-direction: column; min-width: 0; }
  .recruiter-chat__launcher-label { display: flex; align-items: center; gap: .3rem; margin-bottom: .15rem; color: #bfdbfe; font: 700 .64rem/1.2 var(--font-mono); letter-spacing: .08em; text-transform: uppercase; }
  .recruiter-chat__launcher-copy strong { font-size: .94rem; line-height: 1.25; letter-spacing: -.01em; }
  .recruiter-chat__launcher-copy small { color: rgba(255,255,255,.72); font-size: .69rem; line-height: 1.35; }
  .recruiter-chat__launcher-icon { position: relative; flex: 0 0 auto; display: grid; place-items: center; width: 52px; height: 52px; color: white; background: rgba(255,255,255,.13); border: 1px solid rgba(255,255,255,.22); border-radius: 15px; box-shadow: inset 0 1px 0 rgba(255,255,255,.12); }
  .recruiter-chat__status { position: absolute; top: -3px; right: -3px; width: 12px; height: 12px; background: var(--green); border: 2px solid #1d4ed8; border-radius: 50%; box-shadow: 0 0 0 3px rgba(34,197,94,.16); }
  .recruiter-chat__panel { width: min(390px, calc(100vw - 2rem)); height: min(620px, calc(100vh - 2rem)); overflow: hidden; background: rgba(17,17,19,.98); border: 1px solid var(--border-light); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); backdrop-filter: blur(18px); }
  .recruiter-chat__panel:not([hidden]) { display: flex; flex-direction: column; animation: chat-enter .2s ease-out; }
  .recruiter-chat__header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 1.125rem; border-bottom: 1px solid var(--border); background: var(--accent-05); }
  .recruiter-chat__eyebrow { margin: 0 0 .1rem; color: var(--accent); font: 600 .7rem/1 var(--font-mono); text-transform: uppercase; letter-spacing: .08em; }
  .recruiter-chat__header h2 { margin: 0; font-size: .98rem; line-height: 1.3; }
  .recruiter-chat__close { display: grid; place-items: center; width: 36px; height: 36px; color: var(--text-secondary); background: transparent; border: 0; border-radius: var(--radius-sm); cursor: pointer; }
  .recruiter-chat__close:hover { color: var(--text); background: var(--white-05); }
  .recruiter-chat__messages { flex: 1; display: flex; flex-direction: column; gap: 1.15rem; overflow-y: auto; padding: 1.15rem 1rem; scroll-behavior: smooth; scrollbar-width: thin; }
  .recruiter-chat__message { display: flex; flex-direction: column; width: 92%; font-size: .875rem; line-height: 1.65; overflow-wrap: anywhere; }
  .recruiter-chat__message--assistant { align-self: flex-start; }
  .recruiter-chat__message--user { align-self: flex-end; align-items: flex-end; }
  .recruiter-chat__message-meta { display: flex; align-items: center; gap: .4rem; margin: 0 .25rem .4rem; color: var(--text-muted); font: 600 .65rem/1.2 var(--font-mono); letter-spacing: .035em; text-transform: uppercase; }
  .recruiter-chat__message--user .recruiter-chat__message-meta { color: #93c5fd; }
  .recruiter-chat__avatar { display: grid; place-items: center; width: 20px; height: 20px; color: #bfdbfe; background: var(--accent-btn); border-radius: 6px; font-size: .7rem; }
  .recruiter-chat__message-content { width: fit-content; max-width: 100%; padding: .85rem 1rem; border-radius: 15px; box-shadow: 0 5px 16px rgba(0,0,0,.14); }
  .recruiter-chat__message--assistant .recruiter-chat__message-content { color: #d4d4d8; background: linear-gradient(145deg, #1b1b20, #151519); border: 1px solid #34343a; border-left: 3px solid var(--accent); border-top-left-radius: 5px; }
  .recruiter-chat__message--user .recruiter-chat__message-content { color: white; background: linear-gradient(135deg, var(--accent-btn), #4338ca); border: 1px solid rgba(147,197,253,.38); border-bottom-right-radius: 5px; white-space: pre-wrap; }
  .recruiter-chat__message-content p { margin: 0; }
  .recruiter-chat__message-content p + p { margin-top: .8rem; padding-top: .75rem; border-top: 1px solid rgba(161,161,170,.14); }
  .recruiter-chat__message[data-streaming] .recruiter-chat__message-content::after { content: ""; display: inline-block; width: 7px; height: 1em; margin-left: 4px; vertical-align: -2px; background: var(--accent); border-radius: 1px; animation: chat-caret .8s infinite; }
  .recruiter-chat__message :global(.chat-list-item) { display: block; margin-top: .35rem; padding-left: .15rem; }
  .recruiter-chat__message strong { color: white; font-weight: 650; }
  .recruiter-chat__suggestions { padding: .25rem 1rem .85rem; }
  .recruiter-chat__suggestions > p { margin: 0 0 .5rem; color: var(--text-muted); font: 600 .65rem/1.2 var(--font-mono); letter-spacing: .04em; text-transform: uppercase; }
  .recruiter-chat__suggestion-list { display: flex; gap: .5rem; overflow-x: auto; padding: .1rem .1rem .35rem; scrollbar-width: thin; scroll-snap-type: x proximity; }
  .recruiter-chat__suggestions button { flex: 0 0 auto; display: flex; align-items: center; gap: .45rem; max-width: 245px; padding: .58rem .72rem; color: #d4d4d8; background: linear-gradient(145deg, rgba(59,130,246,.13), rgba(67,56,202,.08)); border: 1px solid var(--accent-30); border-radius: 10px; font-size: .73rem; line-height: 1.35; text-align: left; cursor: pointer; scroll-snap-align: start; transition: color var(--transition), border-color var(--transition), transform var(--transition), background var(--transition); }
  .recruiter-chat__suggestions button span { font-size: .9rem; }
  .recruiter-chat__suggestions button:hover { color: white; background: rgba(59,130,246,.2); border-color: var(--accent); transform: translateY(-1px); }
  .recruiter-chat__form { display: flex; align-items: flex-end; gap: .5rem; margin: 0 .75rem; padding: .5rem; background: var(--bg-card); border: 1px solid var(--border-light); border-radius: var(--radius); }
  .recruiter-chat__form:focus-within { border-color: var(--accent); }
  .recruiter-chat__form textarea { flex: 1; min-height: 38px; max-height: 112px; resize: none; padding: .5rem; color: var(--text); background: transparent; border: 0; font: inherit; line-height: 1.4; }
  .recruiter-chat__form textarea::placeholder { color: var(--text-muted); }
  .recruiter-chat__form textarea:focus { outline: 0; }
  .recruiter-chat__form button { flex: 0 0 auto; display: grid; place-items: center; width: 38px; height: 38px; color: white; background: var(--accent-btn); border: 0; border-radius: var(--radius-sm); cursor: pointer; }
  .recruiter-chat__form button:disabled { opacity: .55; cursor: wait; }
  .recruiter-chat__notice { margin: .55rem .75rem .7rem; color: var(--text-muted); font-size: .64rem; line-height: 1.35; text-align: center; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  @keyframes chat-enter { from { opacity: 0; transform: translateY(10px) scale(.98); } }
  @keyframes chat-caret { 50% { opacity: 0; } }
  @keyframes chat-launcher-enter { from { opacity: 0; transform: translateY(12px); } }
  @keyframes chat-attention { 0%, 82%, 100% { transform: translateY(0); } 87% { transform: translateY(-4px); } 92% { transform: translateY(0); } 96% { transform: translateY(-2px); } }
  @keyframes chat-shimmer { 0%, 72% { left: -35%; } 88%, 100% { left: 130%; } }
  @media (max-width: 520px) {
    .recruiter-chat { right: 1rem; bottom: 1rem; }
    .recruiter-chat__launcher { min-width: 0; padding: .55rem; gap: .65rem; border-radius: 16px; }
    .recruiter-chat__launcher-copy { padding-left: .25rem; }
    .recruiter-chat__launcher-copy strong { font-size: .84rem; }
    .recruiter-chat__launcher-copy small { display: none; }
    .recruiter-chat__launcher-icon { width: 46px; height: 46px; border-radius: 13px; }
    .recruiter-chat__panel { position: fixed; inset: .75rem; width: auto; height: auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .recruiter-chat__panel:not([hidden]), .recruiter-chat__launcher, .recruiter-chat__launcher::before { animation: none; }
  }
</style>
