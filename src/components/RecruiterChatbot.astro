<div class="recruiter-chat" data-chatbot>
  <button class="recruiter-chat__launcher" type="button" aria-label="Ouvrir l'assistant IA" aria-expanded="false" data-chat-open>
    <span class="recruiter-chat__launcher-copy">
      <span class="recruiter-chat__launcher-label">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.9 5.1L5 10l5.1 1.9L12 17l1.9-5.1L19 10l-5.1-1.9Z"/><path d="m5 3-.6 1.4L3 5l1.4.6L5 7l.6-1.4L7 5l-1.4-.6Z"/></svg>
        Assistant IA
      </span>
      <strong>Vous recrutez ?</strong>
      <small>Interrogez mon profil technique</small>
    </span>
    <span class="recruiter-chat__launcher-icon" aria-hidden="true">
      <span class="recruiter-chat__status"></span>
      <svg width="27" height="27" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>
    </span>
  </button>

  <section class="recruiter-chat__panel" role="dialog" aria-modal="false" aria-labelledby="recruiter-chat-title" hidden data-chat-panel>
    <header class="recruiter-chat__header">
      <div>
        <p class="recruiter-chat__eyebrow">Assistant IA de Christophe</p>
        <h2 id="recruiter-chat-title">Explorez mon profil technique</h2>
      </div>
      <div class="recruiter-chat__header-actions">
        <button type="button" aria-label="Effacer la conversation" title="Nouvelle conversation" data-chat-reset>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
        </button>
        <button type="button" aria-label="Agrandir le chatbot" title="Plein écran" aria-pressed="false" data-chat-fullscreen>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-fullscreen-icon><path d="M8 3H3v5M16 3h5v5M8 21H3v-5M16 21h5v-5"/></svg>
        </button>
        <button class="recruiter-chat__close" type="button" aria-label="Fermer l'assistant" title="Fermer" data-chat-close>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </header>

    <div class="recruiter-chat__messages" aria-live="polite" aria-busy="false" data-chat-messages></div>

    <div class="recruiter-chat__suggestions" data-chat-suggestions>
      <p data-suggestions-title>Quelques pistes pour commencer</p>
      <div class="recruiter-chat__suggestion-list">
        <button type="button" data-question="Pourquoi vous recruter ?"><span>👋</span> Pourquoi vous recruter ?</button>
        <button type="button" data-question="Quel poste recherchez-vous ?"><span>🎯</span> Quel poste recherchez-vous ?</button>
        <button type="button" data-question="Quel projet démontre le mieux votre niveau ?"><span>🚀</span> Quel projet démontre le mieux votre niveau ?</button>
        <button type="button" data-question="Expliquez-moi l'architecture de SmartPlanning"><span>🏗️</span> Expliquez-moi l'architecture de SmartPlanning</button>
        <button type="button" data-question="Quelle est votre stratégie de tests ?"><span>🧪</span> Quelle est votre stratégie de tests ?</button>
        <button type="button" data-question="Quelle expérience avez-vous du travail en équipe ?"><span>🤝</span> Quelle expérience avez-vous du travail en équipe ?</button>
        <button type="button" data-question="Comment utilisez-vous l'IA pour développer ?"><span>🤖</span> Comment utilisez-vous l'IA pour développer ?</button>
        <button type="button" data-question="Parlez-moi d'un problème technique complexe"><span>🔍</span> Parlez-moi d'un problème technique complexe</button>
        <button type="button" data-question="Quelles sont vos disponibilités et votre mobilité ?"><span>📍</span> Quelles sont vos disponibilités et votre mobilité ?</button>
        <button type="button" data-question="Quels sont vos axes de progression ?"><span>📈</span> Quels sont vos axes de progression ?</button>
      </div>
    </div>

    <form class="recruiter-chat__form" data-chat-form>
      <label class="sr-only" for="recruiter-chat-input">Votre question sur le profil de Christophe</label>
      <textarea id="recruiter-chat-input" rows="1" maxlength="2000" placeholder="Posez une question sur mon profil..." required data-chat-input></textarea>
      <button type="submit" aria-label="Envoyer la question" data-chat-send>
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </form>
    <p class="recruiter-chat__notice">Réponses générées par IA à partir d'informations rédigées et validées par Christophe.</p>
  </section>
</div>

<script>
  type ChatRole = "user" | "assistant";
  interface ChatMessage { role: ChatRole; content: string }
  interface ChatMedia { pattern: RegExp; image: string; title: string; description: string; url: string }

  const root = document.querySelector<HTMLElement>("[data-chatbot]");
  if (root) {
    const openButton = root.querySelector<HTMLButtonElement>("[data-chat-open]")!;
    const closeButton = root.querySelector<HTMLButtonElement>("[data-chat-close]")!;
    const resetButton = root.querySelector<HTMLButtonElement>("[data-chat-reset]")!;
    const fullscreenButton = root.querySelector<HTMLButtonElement>("[data-chat-fullscreen]")!;
    const fullscreenIcon = root.querySelector<SVGElement>("[data-fullscreen-icon]")!;
    const panel = root.querySelector<HTMLElement>("[data-chat-panel]")!;
    const messagesElement = root.querySelector<HTMLElement>("[data-chat-messages]")!;
    const suggestions = root.querySelector<HTMLElement>("[data-chat-suggestions]")!;
    const suggestionsTitle = root.querySelector<HTMLElement>("[data-suggestions-title]")!;
    const suggestionList = root.querySelector<HTMLElement>(".recruiter-chat__suggestion-list")!;
    const form = root.querySelector<HTMLFormElement>("[data-chat-form]")!;
    const input = root.querySelector<HTMLTextAreaElement>("[data-chat-input]")!;
    const sendButton = root.querySelector<HTMLButtonElement>("[data-chat-send]")!;
    const storageKey = "krismos_recruiter_chat_v1";
    let conversation: ChatMessage[] = [];
    let sending = false;

    const INITIAL_SUGGESTIONS: [string, string][] = [
      ["👋", "Pourquoi vous recruter ?"],
      ["🎯", "Quel poste recherchez-vous ?"],
      ["🚀", "Quel projet démontre le mieux votre niveau ?"],
      ["🏗️", "Expliquez-moi l'architecture de SmartPlanning"],
      ["🧪", "Quelle est votre stratégie de tests ?"],
      ["🤝", "Quelle expérience avez-vous du travail en équipe ?"],
      ["🤖", "Comment utilisez-vous l'IA pour développer ?"],
      ["🔍", "Parlez-moi d'un problème technique complexe"],
      ["📍", "Quelles sont vos disponibilités et votre mobilité ?"],
      ["📈", "Quels sont vos axes de progression ?"],
    ];

    const CHAT_MEDIA: ChatMedia[] = [
      { pattern: /planning|calendrier|créneau|conflit|drag and drop/i, image: "/images/blog/capture6.webp", title: "Planning SmartPlanning", description: "Vue hebdomadaire et créneaux interactifs", url: "/blog/05-developpement-fonctionnalites/" },
      { pattern: /architecture en couche|quatre couche|server component|server action|pattern strategy|pattern observer/i, image: "/images/blog/architecture-en-couche.webp", title: "Architecture en quatre couches", description: "Présentation, métier, données et infrastructure", url: "/blog/04-architecture-nextjs-saas/" },
      { pattern: /base de données|postgresql|prisma|multi-tenant|multitenant|mcd|merise/i, image: "/images/blog/mcd.webp", title: "Modèle de données SmartPlanning", description: "MCD du SaaS multi-tenant", url: "/blog/03-conception-base-de-donnees/" },
      { pattern: /test|vitest|playwright|non-régression|qualité logicielle/i, image: "/images/blog/strategie-tests.svg", title: "Stratégie de tests", description: "Tests unitaires, intégration, E2E et CI", url: "/blog/06-strategie-de-tests/" },
      { pattern: /ci\/cd|pipeline|github actions|docker|déploiement|vps|nginx/i, image: "/images/blog/pipeline.webp", title: "Pipeline CI/CD", description: "Contrôles automatisés avant déploiement", url: "/blog/07-cicd-docker-deploiement/" },
      { pattern: /jira|backlog|sprint|kanban|agile/i, image: "/images/blog/jira4.webp", title: "Backlog Jira", description: "Epics, stories et sprints thématiques", url: "/blog/02-gestion-de-projet-agile/" },
      { pattern: /confluence|documentation|documenter/i, image: "/images/blog/confluence2.webp", title: "Documentation Confluence", description: "Compétences et preuves documentées", url: "/blog/02-gestion-de-projet-agile/" },
      { pattern: /analyse des besoins|persona|user stor|product owner|produit/i, image: "/images/blog/personas.webp", title: "Personas SmartPlanning", description: "Quatre rôles et besoins métier", url: "/blog/01-analyse-des-besoins/" },
      { pattern: /figma|maquette|\bui\b|\bux\b|interface/i, image: "/images/blog/maquette2.webp", title: "Maquette du dashboard", description: "Conception Figma avant développement", url: "/blog/01-analyse-des-besoins/" },
      { pattern: /staka|manuscrit|édition/i, image: "/images/projects/livrestaka.webp", title: "Staka Livres", description: "Plateforme fullstack réalisée pour un client", url: "https://livrestaka.fr/" },
      { pattern: /coachtfe|tfe infirmier/i, image: "/images/projects/coachtfe.webp", title: "CoachTFE", description: "Refonte et SEO pour un client réel", url: "https://coachtfe.fr/" },
      { pattern: /cabinet infirmier|graslin|doctolib/i, image: "/images/projects/graslin.webp", title: "Cabinet Infirmier Graslin", description: "Site responsive et SEO local", url: "https://cabinet-infirmier-graslin.fr/" },
      { pattern: /kocinaspeed|symfony|recette/i, image: "/images/projects/kocinaspeed.webp", title: "Kocinaspeed", description: "Projet Symfony avec chatbot IA", url: "https://kocinaspeed.fr/" },
      { pattern: /smartplanning|saas de gestion/i, image: "/images/projects/smart.webp", title: "SmartPlanning", description: "SaaS de gestion d'équipes et de plannings", url: "https://smartplanning.fr/" },
      { pattern: /parcours|profil|cv|recrut|formation|diplôme/i, image: "/images/portfolio/chris7.webp", title: "CV de Christophe", description: "Parcours, compétences et coordonnées", url: "/docs/cv-christophe-mostefaoui.pdf" },
    ];

    const escapeHtml = (value: string) => value.replace(/[&<>"']/g, (character) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#039;",
    })[character]!);

    const normalizeTypography = (value: string) => value
      .replace(/\s*[\u2013\u2014]\s*/g, ": ")
      .replace(/:\s*:/g, ":");

    const linkIcon = (target: string) => {
      const lower = target.toLowerCase();
      if (lower.startsWith("mailto:")) return "✉️";
      if (lower.includes("linkedin.com")) return "💼";
      if (lower.includes("github.com")) return "💻";
      if (lower.includes("smartplanning.fr")) return "📅";
      if (lower.includes("christophe-dev-freelance.fr")) return "🌐";
      if (lower.includes("cv-christophe")) return "📄";
      if (lower.includes("krismos.fr")) return "🧑‍💻";
      return "🔗";
    };

    const linkify = (escapedValue: string) => {
      const links: string[] = [];
      const storeLink = (label: string, target: string) => {
        const external = !target.startsWith("mailto:");
        const attributes = external ? ' target="_blank" rel="noopener noreferrer"' : "";
        const token = `@@CHATLINK${links.length}@@`;
        links.push(`<a class="recruiter-chat__link" href="${target}"${attributes}><span aria-hidden="true">${linkIcon(target)}</span>${label}</a>`);
        return token;
      };

      let output = escapedValue.replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g, (_match, label: string, target: string) =>
        storeLink(label, target)
      );
      output = output.replace(/[\w.+-]+@[\w.-]+\.[A-Za-z]{2,}/g, (email) =>
        storeLink(email, `mailto:${email}`)
      );
      output = output.replace(/https?:\/\/[^\s<]+/g, (rawTarget) => {
        const target = rawTarget.replace(/[.,;:!?)\]*]+$/, "");
        return storeLink(target, target) + rawTarget.slice(target.length);
      });
      return output.replace(/@@CHATLINK(\d+)@@/g, (_match, index: string) => links[Number(index)] || "");
    };

    const formatAssistantText = (value: string) => linkify(escapeHtml(normalizeTypography(value))
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
      .replace(/^\s*-\s+(.+)$/gm, "<span class=\"chat-list-item\">• $1</span>")
      .replace(/\n{2,}/g, "</p><p>")
      .replace(/\n/g, "<br>"));

    const addMediaAttachments = (answer: string, item: HTMLElement) => {
      if (answer.startsWith("Bonjour, je suis l'assistant IA")) return;
      const selected = CHAT_MEDIA.filter((media) => media.pattern.test(answer)).slice(0, 2);
      if (selected.length === 0) return;

      const mediaList = document.createElement("div");
      mediaList.className = "recruiter-chat__media-list";
      selected.forEach((media) => {
        const card = document.createElement("a");
        card.className = "recruiter-chat__media-card";
        card.href = media.url;
        if (media.url.startsWith("http")) {
          card.target = "_blank";
          card.rel = "noopener noreferrer";
        }

        const image = document.createElement("img");
        image.src = media.image;
        image.alt = media.title;
        image.loading = "lazy";
        image.decoding = "async";

        const caption = document.createElement("span");
        caption.className = "recruiter-chat__media-caption";
        const title = document.createElement("strong");
        title.textContent = media.title;
        const description = document.createElement("small");
        description.textContent = media.description;
        caption.append(title, description);
        card.append(image, caption);
        mediaList.appendChild(card);
      });
      item.appendChild(mediaList);
    };

    const addMessage = (message: ChatMessage, streaming = false) => {
      const item = document.createElement("article");
      item.className = `recruiter-chat__message recruiter-chat__message--${message.role}`;
      if (streaming) item.dataset.streaming = "true";

      const meta = document.createElement("div");
      meta.className = "recruiter-chat__message-meta";
      meta.innerHTML = message.role === "assistant"
        ? '<span class="recruiter-chat__avatar" aria-hidden="true">✦</span><span>Assistant IA</span>'
        : '<span>Votre question</span>';

      const content = document.createElement("div");
      content.className = "recruiter-chat__message-content";
      content.innerHTML = message.role === "assistant"
        ? `<p>${formatAssistantText(message.content)}</p>`
        : escapeHtml(message.content);

      item.append(meta, content);
      messagesElement.appendChild(item);
      if (message.role === "assistant" && !streaming) addMediaAttachments(message.content, item);
      messagesElement.scrollTop = messagesElement.scrollHeight;
      return content;
    };

    const setSuggestions = (items: [string, string][], title: string) => {
      suggestionsTitle.textContent = title;
      suggestionList.replaceChildren();
      items.forEach(([icon, question]) => {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.question = question;
        const iconElement = document.createElement("span");
        iconElement.setAttribute("aria-hidden", "true");
        iconElement.textContent = icon;
        button.append(iconElement, document.createTextNode(` ${question}`));
        suggestionList.appendChild(button);
      });
      suggestions.hidden = false;
    };

    const updateSuggestions = (answer: string) => {
      const lower = answer.toLowerCase();
      let contextual: [string, string][] = [];
      if (/smartplanning|architecture|saas|prisma|postgresql/.test(lower)) {
        contextual = [
          ["🔍", "Quel problème technique vous a le plus challengé ?"],
          ["🧱", "Que feriez-vous différemment sur cette architecture ?"],
          ["🔐", "Comment assurez-vous l'isolation multi-tenant ?"],
        ];
      } else if (/test|vitest|playwright|qualité|ci\/cd/.test(lower)) {
        contextual = [
          ["🧪", "Donnez-moi un exemple de test métier important"],
          ["🐛", "Parlez-moi d'une erreur trouvée en production"],
          ["⚙️", "Comment votre CI bloque-t-elle les régressions ?"],
        ];
      } else if (/intelligence artificielle|\bia\b|claude|codex|mcp/.test(lower)) {
        contextual = [
          ["🛡️", "Comment protégez-vous les données sensibles avec l'IA ?"],
          ["🧠", "Comment évitez-vous de dépendre de l'IA ?"],
          ["🔌", "Comment utilisez-vous les MCP avec Jira et Confluence ?"],
        ];
      } else if (/équipe|collabor|pull request|hackathon|communication/.test(lower)) {
        contextual = [
          ["🤝", "Comment réagissez-vous à une critique de code ?"],
          ["⚖️", "Comment gérez-vous un désaccord technique ?"],
          ["🏢", "Quelle culture d'équipe recherchez-vous ?"],
        ];
      } else if (/poste|recrut|disponib|product owner|fullstack/.test(lower)) {
        contextual = [
          ["📍", "Quelle est votre disponibilité et votre mobilité ?"],
          ["🧭", "Préférez-vous le développement ou le produit ?"],
          ["💪", "Quelles sont vos principales forces ?"],
        ];
      } else {
        contextual = [
          ["🚀", "Quel projet démontre le mieux votre niveau ?"],
          ["💡", "Quelle valeur apporteriez-vous à une équipe ?"],
          ["📈", "Quels sont vos axes de progression ?"],
        ];
      }

      const asked = new Set(conversation.filter((message) => message.role === "user").map((message) => message.content.toLowerCase()));
      const filtered = contextual.filter(([, question]) => !asked.has(question.toLowerCase()));
      setSuggestions((filtered.length >= 2 ? filtered : contextual).slice(0, 3), "Pour poursuivre l'échange");
    };

    const saveConversation = () => {
      try { sessionStorage.setItem(storageKey, JSON.stringify(conversation.slice(-20))); } catch { /* stockage indisponible */ }
    };

    const restoreConversation = () => {
      try {
        const saved = JSON.parse(sessionStorage.getItem(storageKey) || "[]");
        if (Array.isArray(saved)) {
          conversation = saved.filter((item): item is ChatMessage =>
            item && ["user", "assistant"].includes(item.role) && typeof item.content === "string"
          ).slice(-20);
        }
      } catch { conversation = []; }
      if (conversation.length === 0) {
        conversation = [{ role: "assistant", content: "Bonjour, je suis l'assistant IA du portfolio de Christophe. Je peux vous aider à évaluer son parcours, ses projets et ses choix techniques." }];
      }
      conversation.forEach((message) => addMessage(message));
    };

    const setOpen = (isOpen: boolean) => {
      panel.hidden = !isOpen;
      openButton.hidden = isOpen;
      openButton.setAttribute("aria-expanded", String(isOpen));
      if (isOpen) window.setTimeout(() => input.focus(), 50);
    };

    const setSending = (isSending: boolean) => {
      sending = isSending;
      input.disabled = isSending;
      sendButton.disabled = isSending;
      resetButton.disabled = isSending;
      messagesElement.setAttribute("aria-busy", String(isSending));
    };

    const consumeSse = async (response: Response, content: HTMLElement) => {
      if (!response.body) throw new Error("Flux indisponible");
      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      let answer = "";
      let displayed = "";
      let streamFinished = false;

      const typewriter = window.setInterval(() => {
        const remaining = answer.length - displayed.length;
        if (remaining <= 0) return;
        const step = remaining > 240 ? 3 : remaining > 80 ? 2 : 1;
        displayed = answer.slice(0, displayed.length + step);
        content.innerHTML = `<p>${formatAssistantText(displayed)}</p>`;
        messagesElement.scrollTop = messagesElement.scrollHeight;
      }, 24);

      const parseLine = (line: string) => {
        if (!line.startsWith("data:")) return;
        const data = line.slice(5).trim();
        if (!data || data === "[DONE]") return;
        try {
          const token = JSON.parse(data).choices?.[0]?.delta?.content;
          if (typeof token === "string") {
            answer += token;
          }
        } catch { /* un événement incomplet reste ignoré */ }
      };

      try {
        while (true) {
          const { value, done } = await reader.read();
          buffer += decoder.decode(value || new Uint8Array(), { stream: !done });
          const lines = buffer.split(/\r?\n/);
          buffer = lines.pop() || "";
          lines.forEach(parseLine);
          if (done) break;
        }
        if (buffer) parseLine(buffer);
        if (!answer.trim()) throw new Error("Réponse vide");
        streamFinished = true;

        await new Promise<void>((resolve) => {
          const waitForTypewriter = window.setInterval(() => {
            if (streamFinished && displayed.length >= answer.length) {
              window.clearInterval(waitForTypewriter);
              resolve();
            }
          }, 25);
        });
      } finally {
        window.clearInterval(typewriter);
      }
      displayed = answer;
      content.innerHTML = `<p>${formatAssistantText(answer)}</p>`;
      return answer.trim();
    };

    const sendQuestion = async (question: string) => {
      const cleanQuestion = question.trim();
      if (!cleanQuestion || sending) return;
      suggestions.hidden = true;
      const userMessage: ChatMessage = { role: "user", content: cleanQuestion };
      conversation.push(userMessage);
      addMessage(userMessage);
      input.value = "";
      input.style.height = "auto";
      setSending(true);

      const assistantContent = addMessage({ role: "assistant", content: "Analyse en cours..." }, true);
      const assistantItem = assistantContent.closest<HTMLElement>(".recruiter-chat__message")!;
      try {
        const response = await fetch("/api/chat.php", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages: conversation.slice(-10) }),
        });
        if (!response.ok) throw new Error(`Proxy HTTP ${response.status}`);
        assistantContent.textContent = "";
        const answer = await consumeSse(response, assistantContent);
        conversation.push({ role: "assistant", content: answer });
        addMediaAttachments(answer, assistantItem);
        saveConversation();
        updateSuggestions(answer);
      } catch (error) {
        console.error("Chatbot Mistral:", error);
        const fallback = "L'assistant est temporairement indisponible. Vous pouvez consulter le CV ou contacter Christophe à christophe.mostefaoui.dev@gmail.com.";
        assistantContent.innerHTML = `<p>${formatAssistantText(fallback)}</p>`;
        conversation.push({ role: "assistant", content: fallback });
        saveConversation();
        setSuggestions([["✉️", "Comment contacter Christophe ?"], ["🔄", "Pourquoi vous recruter ?"]], "Vous pouvez aussi demander");
      } finally {
        delete assistantItem.dataset.streaming;
        setSending(false);
        input.focus();
      }
    };

    const setFullscreen = (isFullscreen: boolean) => {
      panel.classList.toggle("recruiter-chat__panel--fullscreen", isFullscreen);
      fullscreenButton.setAttribute("aria-pressed", String(isFullscreen));
      fullscreenButton.setAttribute("aria-label", isFullscreen ? "Réduire le chatbot" : "Agrandir le chatbot");
      fullscreenButton.title = isFullscreen ? "Réduire" : "Plein écran";
      fullscreenIcon.innerHTML = isFullscreen
        ? '<path d="M8 3v5H3M16 3v5h5M8 21v-5H3M16 21v-5h5"/>'
        : '<path d="M8 3H3v5M16 3h5v5M8 21H3v-5M16 21h5v-5"/>';
      window.setTimeout(() => { messagesElement.scrollTop = messagesElement.scrollHeight; }, 50);
    };

    const resetConversation = () => {
      if (sending) return;
      conversation = [];
      try { sessionStorage.removeItem(storageKey); } catch { /* stockage indisponible */ }
      messagesElement.replaceChildren();
      restoreConversation();
      setSuggestions(INITIAL_SUGGESTIONS, "Quelques pistes pour commencer");
      input.value = "";
      input.style.height = "auto";
      input.focus();
    };

    restoreConversation();
    if (conversation.length > 1) {
      const lastAnswer = [...conversation].reverse().find((message) => message.role === "assistant");
      if (lastAnswer) updateSuggestions(lastAnswer.content);
    }
    openButton.addEventListener("click", () => setOpen(true));
    closeButton.addEventListener("click", () => { setFullscreen(false); setOpen(false); });
    resetButton.addEventListener("click", resetConversation);
    fullscreenButton.addEventListener("click", () => setFullscreen(!panel.classList.contains("recruiter-chat__panel--fullscreen")));
    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || panel.hidden) return;
      if (panel.classList.contains("recruiter-chat__panel--fullscreen")) setFullscreen(false);
      else setOpen(false);
    });
    form.addEventListener("submit", (event) => { event.preventDefault(); sendQuestion(input.value); });
    input.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && !event.shiftKey) { event.preventDefault(); sendQuestion(input.value); }
    });
    input.addEventListener("input", () => {
      input.style.height = "auto";
      input.style.height = `${Math.min(input.scrollHeight, 112)}px`;
    });
    suggestions.addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("button[data-question]");
      if (button?.dataset.question) sendQuestion(button.dataset.question);
    });
  }
</script>

