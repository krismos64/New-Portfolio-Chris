---
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth <= 3);

let h2Counter = 0;
const numberedHeadings = filteredHeadings.map((h) => {
  if (h.depth === 2) h2Counter++;
  return { ...h, h2Index: h.depth === 2 ? h2Counter : null };
});
---

{numberedHeadings.length > 0 && (
  <nav class="toc" aria-label="Table des matières" id="toc">

    <div class="toc-header">
      <div class="toc-label">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/>
        </svg>
        <span>Dans cet article</span>
      </div>
      <span class="toc-badge">{h2Counter} sections</span>
    </div>

    <div class="toc-progress-wrap" aria-hidden="true">
      <div class="toc-progress-fill" id="tocProgress"></div>
    </div>

    <ol class="toc-list" id="toc-list">
      {numberedHeadings.map((heading) => (
        <li class={`toc-item toc-d${heading.depth}`}>
          <a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug}>
            {heading.depth === 2 ? (
              <span class="toc-num">{String(heading.h2Index).padStart(2, '0')}</span>
            ) : (
              <span class="toc-sub-indent" aria-hidden="true">↳</span>
            )}
            <span class="toc-text">{heading.text}</span>
          </a>
        </li>
      ))}
    </ol>

  </nav>
)}

<script>
  const tocProgress = document.getElementById('tocProgress');
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-link'));
  const headingEls = Array.from(document.querySelectorAll<HTMLElement>('.prose h2, .prose h3'));

  if (headingEls.length > 0 && tocLinks.length > 0) {
    const activate = (slug: string) => {
      tocLinks.forEach((l) => l.classList.toggle('is-active', l.dataset.slug === slug));
      const idx = headingEls.findIndex((el) => el.id === slug);
      if (idx >= 0 && tocProgress) {
        tocProgress.style.width = `${Math.round(((idx + 1) / headingEls.length) * 100)}%`;
      }
    };
    activate(headingEls[0]?.id ?? '');

    const obs = new IntersectionObserver(
      (entries) => {
        const hit = entries.filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
        if (hit) activate((hit.target as HTMLElement).id);
      },
      { rootMargin: '-5% 0px -65% 0px', threshold: 0 }
    );
    headingEls.forEach((el) => obs.observe(el));
  }
</script>

<style>
  /* ========== Conteneur ========== */
  .toc {
    position: relative;
    margin-bottom: 3rem;
    border-radius: 12px;
    overflow: hidden;
    background: #111114;
    border: 1px solid #2a2a2e;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
  }

  /* Bande top accent */
  .toc::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: linear-gradient(90deg, #3b82f6, #a855f7);
  }

  /* ========== Header ========== */
  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem 0.75rem;
  }

  .toc-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #e4e4e7;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .toc-label svg {
    color: #3b82f6;
    flex-shrink: 0;
  }

  .toc-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: #3b82f6;
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.22);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    letter-spacing: 0.04em;
  }

  /* ========== Barre de progression ========== */
  .toc-progress-wrap {
    height: 2px;
    background: #27272a;
    margin: 0 1.25rem 0.5rem;
    border-radius: 2px;
    overflow: hidden;
  }

  .toc-progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #3b82f6, #a855f7);
    border-radius: 2px;
    transition: width 0.35s ease;
  }

  /* ========== Liste ========== */
  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0 0.75rem;
  }

  /* ========== Items ========== */
  .toc-item {
    margin: 0;
  }

  /* Séparateur visuel avant chaque H2 (sauf le premier) */
  .toc-d2 + .toc-d2 {
    margin-top: 0.125rem;
  }

  /* Sous-sections */
  .toc-d3 {
    background: rgba(255, 255, 255, 0.015);
  }

  /* ========== Liens ========== */
  .toc-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.25rem;
    text-decoration: none;
    transition: background 0.15s ease;
    position: relative;
  }

  .toc-link:hover {
    background: rgba(59, 130, 246, 0.06);
  }

  /* Indicateur actif */
  .toc-link.is-active {
    background: rgba(59, 130, 246, 0.08);
  }

  .toc-link.is-active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #3b82f6;
    border-radius: 0 2px 2px 0;
  }

  /* ========== Numéro H2 ========== */
  .toc-num {
    flex-shrink: 0;
    width: 2rem;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    color: #52525b;
    letter-spacing: 0.05em;
    transition: color 0.15s ease;
    line-height: 1;
  }

  .toc-link:hover .toc-num,
  .toc-link.is-active .toc-num {
    color: #3b82f6;
  }

  /* ========== Flèche H3 ========== */
  .toc-sub-indent {
    flex-shrink: 0;
    width: 2rem;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: #3f3f46;
    transition: color 0.15s ease;
    line-height: 1;
  }

  .toc-link:hover .toc-sub-indent,
  .toc-link.is-active .toc-sub-indent {
    color: #3b82f6;
  }

  /* ========== Texte ========== */
  .toc-text {
    font-size: 0.875rem;
    font-weight: 400;
    color: #71717a;
    line-height: 1.4;
    transition: color 0.15s ease;
  }

  .toc-d2 .toc-text {
    color: #a1a1aa;
    font-weight: 500;
  }

  .toc-link:hover .toc-text {
    color: #e4e4e7;
  }

  .toc-link.is-active .toc-text {
    color: #fafafa;
    font-weight: 600;
  }

  .toc-d3 .toc-text {
    font-size: 0.8125rem;
    font-weight: 400;
    color: #52525b;
  }

  .toc-d3 .toc-link.is-active .toc-text {
    color: #a1a1aa;
    font-weight: 500;
  }

  /* ========== Responsive ========== */
  @media (max-width: 640px) {
    .toc-link {
      padding: 0.45rem 1rem;
    }
    .toc-text {
      font-size: 0.8125rem;
    }
  }
</style>
