---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title,
  description = "Développeur Fullstack Next.js / React — Je conçois et construis des applications SaaS de A à Z. Portfolio de Christophe Mostefaoui.",
  image = "/images/portfolio/chris7.jpg",
  url = "https://krismos.fr/"
} = Astro.props;

const fullImageUrl = new URL(image, Astro.site || 'https://krismos.fr').href;
const canonicalUrl = new URL(url, Astro.site || 'https://krismos.fr').href;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Christophe Mostefaoui — Portfolio" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/portfolio/favicon.png" />

    <!-- Font : Inter (Apple/Google style) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Christophe Mostefaoui",
      "jobTitle": "Développeur Fullstack Next.js / React",
      "description": description,
      "image": fullImageUrl,
      "url": canonicalUrl,
      "sameAs": [
        "https://www.linkedin.com/in/christophemostefaoui/",
        "https://github.com/krismos64"
      ],
      "knowsAbout": [
        "Next.js", "React", "TypeScript", "Node.js", "PostgreSQL",
        "Prisma", "Docker", "Tailwind CSS", "Astro"
      ],
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "La Fabrique Numérique Paloise"
      }
    })} />
  </head>

  <body>
    <a href="#main-content" class="skip-link">Passer au contenu</a>

    <slot />

    <footer class="site-footer">
      <p>&copy; 2026 Christophe Mostefaoui</p>
    </footer>

    <!-- Fond animé : fragments de syntaxe dev flottants -->
    <canvas id="code-bg"></canvas>
    <script>
      (function () {
        const canvas = document.getElementById("code-bg") as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const snippets = [
          "{ }", "=>", "< />", "//", "&&", "||", "===",
          "0", "1", "( )", "[ ]", "::", "/*", "*/",
          "fn()", "let", "if", "else", "true", "null",
          "async", "await", "/>", "</", "import", "export",
          ";", "return", "map()", "=>", "{ }", "::", "&&",
          "...", "??", "!=", "++", "[]", "()", "git",
          "npm", "tsx", ".ts", "/**/"
        ];

        interface Particle {
          x: number;
          y: number;
          text: string;
          speed: number;
          opacity: number;
          size: number;
          drift: number;
          phase: number;
        }

        let particles: Particle[] = [];
        let w = 0;
        let h = 0;
        let animId = 0;

        function resize() {
          w = canvas.width = window.innerWidth;
          h = canvas.height = window.innerHeight;
        }

        function createParticles() {
          const count = Math.floor((w * h) / 28000);
          particles = [];
          for (let i = 0; i < count; i++) {
            particles.push({
              x: Math.random() * w,
              y: Math.random() * h,
              text: snippets[Math.floor(Math.random() * snippets.length)],
              speed: 0.15 + Math.random() * 0.35,
              opacity: 0.15 + Math.random() * 0.15,
              size: 10 + Math.random() * 6,
              drift: (Math.random() - 0.5) * 0.3,
              phase: Math.random() * Math.PI * 2,
            });
          }
        }

        function draw() {
          ctx!.clearRect(0, 0, w, h);
          const time = Date.now() * 0.001;

          for (const p of particles) {
            p.y -= p.speed;
            p.x += Math.sin(time + p.phase) * p.drift;

            if (p.y < -30) {
              p.y = h + 20;
              p.x = Math.random() * w;
              p.text = snippets[Math.floor(Math.random() * snippets.length)];
            }
            if (p.x < -30) p.x = w + 20;
            if (p.x > w + 30) p.x = -20;

            ctx!.font = `${p.size}px 'SF Mono', 'Fira Code', monospace`;
            ctx!.fillStyle = `rgba(59, 130, 246, ${p.opacity})`;
            ctx!.fillText(p.text, p.x, p.y);
          }

          animId = requestAnimationFrame(draw);
        }

        resize();
        createParticles();
        draw();

        window.addEventListener("resize", () => {
          resize();
          createParticles();
        });

        // Pause quand l'onglet n'est pas visible
        document.addEventListener("visibilitychange", () => {
          if (document.hidden) {
            cancelAnimationFrame(animId);
          } else {
            draw();
          }
        });
      })();
    </script>

    <!-- Chatbot -->
    <script>
      window.embeddedChatbotConfig = {
        chatbotId: "ChVRrroBokwiXkBw4wCcr",
        domain: "www.chatbase.co",
      };
    </script>
    <script
      src="https://www.chatbase.co/embed.min.js"
      chatbotId="ChVRrroBokwiXkBw4wCcr"
      domain="www.chatbase.co"
      defer
    ></script>
  </body>
</html>

<style is:global>
  /* === Design Tokens === */
  :root {
    --bg: #09090b;
    --bg-alt: #111113;
    --bg-card: #18181b;
    --bg-card-hover: #1f1f23;
    --border: #27272a;
    --border-light: #3f3f46;
    --text: #fafafa;
    --text-secondary: #a1a1aa;
    --text-muted: #71717a;
    --accent: #3b82f6;
    --accent-hover: #2563eb;
    --accent-subtle: rgba(59, 130, 246, 0.1);
    --accent-glow: rgba(59, 130, 246, 0.15);
    --green: #22c55e;
    --green-subtle: rgba(34, 197, 94, 0.1);
    --purple: #a855f7;
    --purple-subtle: rgba(168, 85, 247, 0.1);
    --amber: #f59e0b;
    --amber-subtle: rgba(245, 158, 11, 0.1);
    --radius: 12px;
    --radius-sm: 8px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.4);
    --transition: 0.2s ease;
    --transition-slow: 0.4s ease;
    --max-width: 1200px;
    --nav-height: 64px;
  }

  /* === Reset === */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background-color: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* === Animated Dev Background === */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 50% at 20% 20%, rgba(59, 130, 246, 0.08), transparent),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(168, 85, 247, 0.06), transparent),
      radial-gradient(ellipse 50% 60% at 50% 50%, rgba(59, 130, 246, 0.04), transparent);
    animation: gradientShift 12s ease-in-out infinite alternate;
  }

  /* Canvas flottant de syntaxe dev */
  #code-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* Contenu au-dessus du fond */
  body > *:not(.skip-link):not(#code-bg) {
    position: relative;
    z-index: 2;
  }

  @keyframes gradientShift {
    0% {
      background:
        radial-gradient(ellipse 80% 50% at 20% 20%, rgba(59, 130, 246, 0.08), transparent),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(168, 85, 247, 0.06), transparent),
        radial-gradient(ellipse 50% 60% at 50% 50%, rgba(59, 130, 246, 0.04), transparent);
    }
    100% {
      background:
        radial-gradient(ellipse 80% 50% at 80% 80%, rgba(168, 85, 247, 0.08), transparent),
        radial-gradient(ellipse 60% 40% at 20% 20%, rgba(59, 130, 246, 0.06), transparent),
        radial-gradient(ellipse 50% 60% at 60% 40%, rgba(168, 85, 247, 0.04), transparent);
    }
  }

  /* === Scrollbar === */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--border-light);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }

  /* === Typography === */
  h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition);
  }
  a:hover {
    color: var(--accent-hover);
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* === Skip Link === */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    z-index: 1000;
    font-weight: 600;
  }
  .skip-link:focus {
    top: 1rem;
    color: white;
  }

  /* === Section Styling === */
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--text);
    letter-spacing: -0.03em;
  }

  /* === Footer === */
  .site-footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
    font-size: 0.875rem;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  /* === Animations === */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll reveal via CSS + JS */
  .fade-up {
    opacity: 1;
    transform: translateY(0);
  }
  .fade-up.sr-hidden {
    opacity: 0;
    transform: translateY(24px);
  }
  .fade-up.sr-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  /* === Selection === */
  ::selection {
    background: var(--accent);
    color: white;
  }
</style>
