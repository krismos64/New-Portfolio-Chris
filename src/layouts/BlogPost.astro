---
import Layout from './Layout.astro';
import BlogNav from '../components/BlogNav.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import { categoryColors, categoryLabels } from '../data/categories';

export interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  image?: string;
  order: number;
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
  headings: { depth: number; slug: string; text: string }[];
}

const {
  title,
  description,
  date,
  updatedDate,
  category,
  tags,
  image,
  order,
  prevPost,
  nextPost,
  headings,
} = Astro.props;

const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = `https://krismos.fr/blog/${Astro.params.slug}/`;
const orderPadded = String(order).padStart(2, '0');
---

<Layout
  title={`${title} — SmartPlanning Blog | Christophe Mostefaoui`}
  description={description}
  image={image}
  url={canonicalUrl}
>
  <!-- Fonts éditoriales -->
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />

  <BlogNav activeLink="blog" />

  <!-- JSON-LD BlogPosting -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": date.toISOString(),
    "dateModified": (updatedDate || date).toISOString(),
    "author": {
      "@type": "Person",
      "name": "Christophe Mostefaoui",
      "url": "https://krismos.fr/"
    },
    "publisher": {
      "@type": "Person",
      "name": "Christophe Mostefaoui"
    },
    "mainEntityOfPage": canonicalUrl,
    "image": image ? new URL(image, 'https://krismos.fr').href : undefined,
    "keywords": tags.join(', '),
    "articleSection": categoryLabels[category] || category,
    "isPartOf": {
      "@type": "Blog",
      "name": "SmartPlanning — Du concept au déploiement",
      "url": "https://krismos.fr/blog/"
    }
  })} />

  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Portfolio", "item": "https://krismos.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://krismos.fr/blog/" },
      { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl }
    ]
  })} />

  <!-- Reading progress -->
  <div class="reading-progress" id="readingProgress" aria-hidden="true"></div>

  <main id="main-content" class="post-layout">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Portfolio</a>
      <span class="breadcrumb-sep" aria-hidden="true">·</span>
      <a href="/blog">Blog</a>
      <span class="breadcrumb-sep" aria-hidden="true">·</span>
      <span class="breadcrumb-current">{title}</span>
    </nav>

    <!-- Hero header -->
    <header class="post-hero">
      <div class="post-hero-inner">
        <div class="post-eyebrow">
          <span class="post-order" aria-label={`Épisode ${orderPadded}`}>{orderPadded}</span>
          <span
            class="post-category-badge"
            style={`--cat: ${categoryColors[category] || 'var(--accent)'}`}
          >
            {categoryLabels[category] || category}
          </span>
          <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>
          {formattedUpdatedDate && (
            <span class="post-updated">↻ {formattedUpdatedDate}</span>
          )}
        </div>

        <h1 class="post-title">{title}</h1>
        <p class="post-lead">{description}</p>

        <div class="post-tags">
          {tags.map((tag) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <!-- Cover illustration -->
    {image && (
      <div class="post-cover-wrap">
        <img
          src={image}
          alt={title}
          class="post-cover"
          loading="eager"
          width="800"
          height="420"
        />
      </div>
    )}

    <!-- Body : TOC + contenu -->
    <div class="post-body">

      {headings.length > 0 && (
        <TableOfContents headings={headings} />
      )}

      <div class="prose">
        <slot />
      </div>
    </div>

    <!-- CTA -->
    <aside class="post-cta" aria-label="Appel à l'action">
      <div class="post-cta-inner">
        <div class="post-cta-icon" aria-hidden="true">✦</div>
        <p class="post-cta-text">Ce projet vous intéresse ?<br />Découvrez mon profil complet.</p>
        <div class="post-cta-links">
          <a href="/docs/cv-christophe-mostefaoui.pdf" target="_blank" rel="noopener noreferrer" class="cta-btn cta-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Voir mon CV
          </a>
          <a href="https://www.linkedin.com/in/christophemostefaoui/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-secondary">LinkedIn</a>
          <a href="/#contact" class="cta-btn cta-secondary">Contact</a>
        </div>
      </div>
    </aside>

    <!-- Navigation prev / next -->
    <nav class="post-nav" aria-label="Navigation entre articles">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}/`} class="post-nav-link post-nav-prev">
          <span class="post-nav-dir">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            Précédent
          </span>
          <span class="post-nav-title">{prevPost.title}</span>
        </a>
      ) : <div />}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}/`} class="post-nav-link post-nav-next">
          <span class="post-nav-dir">
            Suivant
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
          <span class="post-nav-title">{nextPost.title}</span>
        </a>
      ) : <div />}
    </nav>

  </main>
</Layout>

<script>
  const progressBar = document.getElementById('readingProgress');
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
      progressBar.style.width = `${Math.min(progress, 100)}%`;
    }, { passive: true });
  }

  // Reveal paragraphs on scroll
  const paras = document.querySelectorAll<HTMLElement>('.prose > p, .prose > ul, .prose > ol, .prose > blockquote, .prose > pre, .prose > h2, .prose > h3, .prose > table');
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
        revealObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

  paras.forEach((el) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    revealObs.observe(el);
  });
</script>

<style>
  /* ===== Google Fonts — éditoriales ===== */
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400&display=swap');

  /* ===== Progress bar ===== */
  .reading-progress {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    height: 2px;
    width: 0;
    background: linear-gradient(90deg, var(--accent), var(--purple));
    z-index: 200;
    transition: width 0.08s linear;
    pointer-events: none;
  }

  /* ===== Layout wrapper ===== */
  .post-layout {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }

  /* ===== Breadcrumb ===== */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: calc(var(--nav-height) + 2rem);
    margin-bottom: 3rem;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }
  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--transition);
  }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb-sep { color: var(--border-light); }
  .breadcrumb-current {
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 260px;
  }

  /* ===== Hero header ===== */
  .post-hero {
    margin-bottom: 3rem;
    animation: heroIn 0.7s ease both;
  }

  @keyframes heroIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .post-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .post-order {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    letter-spacing: 0.1em;
  }

  .post-category-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cat);
    background: color-mix(in srgb, var(--cat) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--cat) 25%, transparent);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-pill);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .post-updated {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ===== Titre principal ===== */
  .post-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  /* ===== Lead / description ===== */
  .post-lead {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: clamp(1.0625rem, 2vw, 1.2rem);
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
  }

  /* ===== Tags ===== */
  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
    transition: color var(--transition), border-color var(--transition);
  }
  .post-tag:hover {
    color: var(--text-secondary);
    border-color: var(--border-light);
  }

  /* ===== Cover ===== */
  .post-cover-wrap {
    margin-bottom: 3.5rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    animation: heroIn 0.7s ease 0.15s both;
  }

  .post-cover {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ===== Body ===== */
  .post-body {
    animation: heroIn 0.7s ease 0.25s both;
  }

  /* ===== PROSE — le cœur du redesign ===== */
  .prose {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    font-weight: 400;
    line-height: 1.9;
    color: #c4c4cc;
  }

  /* Drop cap premier paragraphe */
  .prose > p:first-of-type::first-letter {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 3.5em;
    line-height: 0.8;
    float: left;
    margin-right: 0.08em;
    margin-top: 0.1em;
    color: var(--text);
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  /* H2 : ligne accent + numérotation implicite */
  .prose :global(h2) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    font-weight: 400;
    color: var(--text);
    margin-top: 4rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    position: relative;
    scroll-margin-top: calc(var(--nav-height) + 1.5rem);
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .prose :global(h2)::before {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 3rem;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }

  /* H3 */
  .prose :global(h3) {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    font-weight: 600;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 0.875rem;
    scroll-margin-top: calc(var(--nav-height) + 1.5rem);
    letter-spacing: -0.01em;
  }

  .prose :global(h3)::before {
    content: '§ ';
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9em;
    opacity: 0.6;
  }

  /* Listes */
  .prose :global(ul) {
    margin-bottom: 1.5rem;
    padding-left: 0;
    list-style: none;
  }

  .prose :global(ul li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.625rem;
  }

  .prose :global(ul li)::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.85em;
    top: 0.1em;
    opacity: 0.7;
  }

  .prose :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    counter-reset: ol-counter;
    list-style: none;
  }

  .prose :global(ol li) {
    counter-increment: ol-counter;
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.625rem;
  }

  .prose :global(ol li)::before {
    content: counter(ol-counter, decimal-leading-zero);
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-size: 0.75em;
    font-weight: 700;
    color: var(--accent);
    top: 0.2em;
    opacity: 0.8;
  }

  /* Blockquote redesigné */
  .prose :global(blockquote) {
    position: relative;
    margin: 2.5rem 0;
    padding: 1.5rem 1.75rem 1.5rem 2rem;
    background: linear-gradient(135deg, var(--accent-08) 0%, transparent 100%);
    border-left: none;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .prose :global(blockquote)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--accent), var(--purple));
    border-radius: 3px 0 0 3px;
  }

  .prose :global(blockquote)::after {
    content: '"';
    position: absolute;
    top: -0.5rem;
    right: 1.25rem;
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 6rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.08;
    pointer-events: none;
  }

  .prose :global(blockquote p) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(1.0625rem, 2vw, 1.2rem);
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 0;
    line-height: 1.7;
  }

  /* Code inline */
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-card);
    color: var(--accent);
    padding: 0.15em 0.45em;
    border-radius: 4px;
    border: 1px solid var(--border);
    font-weight: 500;
  }

  /* Blocs de code — terminal style */
  .prose :global(pre) {
    position: relative;
    margin: 2rem 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  }

  .prose :global(pre)::before {
    content: '';
    display: block;
    height: 36px;
    background: #1c1c1e;
    border-bottom: 1px solid var(--border);
    background-image:
      radial-gradient(circle at 14px 18px, #ff5f57 5px, transparent 5px),
      radial-gradient(circle at 30px 18px, #febc2e 5px, transparent 5px),
      radial-gradient(circle at 46px 18px, #28c840 5px, transparent 5px);
  }

  .prose :global(pre code) {
    display: block;
    background: #0f0f11;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #c9d1d9;
    border: none;
    font-weight: 400;
  }

  /* Strong & em */
  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(em) {
    font-style: italic;
    color: var(--text-secondary);
  }

  /* Liens */
  .prose :global(a) {
    color: var(--accent);
    text-decoration-line: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color var(--transition), text-decoration-style var(--transition);
  }
  .prose :global(a:hover) {
    color: var(--accent-hover);
    text-decoration-style: solid;
  }

  /* HR */
  .prose :global(hr) {
    border: none;
    margin: 3rem auto;
    width: 3rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-light), transparent);
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9375rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .prose :global(thead) {
    background: var(--bg-card);
  }

  .prose :global(th) {
    font-weight: 700;
    color: var(--text);
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--accent);
    text-align: left;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  .prose :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
    vertical-align: top;
  }

  .prose :global(tr:hover td) {
    background: rgba(255,255,255,0.02);
  }

  /* Images */
  .prose :global(img) {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    margin: 2rem 0;
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  }

  /* ===== CTA ===== */
  .post-cta {
    margin-top: 4rem;
    padding: 2.5rem 2rem;
    background: linear-gradient(135deg, var(--bg-card) 0%, color-mix(in srgb, var(--accent) 5%, var(--bg-card)) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .post-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 50% 0%, var(--accent-08), transparent);
    pointer-events: none;
  }

  .post-cta-inner {
    position: relative;
  }

  .post-cta-icon {
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
    display: block;
    opacity: 0.7;
  }

  .post-cta-text {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .post-cta-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 1.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    transition: all var(--transition);
  }

  .cta-primary {
    background: var(--accent);
    color: white;
  }
  .cta-primary:hover {
    background: var(--accent-hover);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--accent-30);
  }

  .cta-secondary {
    background: transparent;
