---
import Layout from '../../layouts/Layout.astro';
import BlogNav from '../../components/BlogNav.astro';
import { getCollection } from 'astro:content';
import { categoryColors, categoryLabels } from '../../data/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { key: 'all', label: 'Tout' },
  { key: 'analyse', label: 'Analyse' },
  { key: 'gestion-projet', label: 'Gestion' },
  { key: 'conception', label: 'Conception' },
  { key: 'developpement', label: 'Dev' },
  { key: 'tests', label: 'Tests' },
  { key: 'deploiement', label: 'Déploiement' },
  { key: 'demo', label: 'Démos' },
];
---

<Layout
  title="Blog SmartPlanning — Du concept au déploiement | Christophe Mostefaoui"
  description="Série d'articles détaillant la création de SmartPlanning, SaaS de gestion d'équipes : analyse des besoins, conception, développement Next.js, CI/CD Docker et déploiement VPS."
  url="https://krismos.fr/blog/"
>
  <BlogNav activeLink="blog" />

  <!-- JSON-LD Blog -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "SmartPlanning — Du concept au déploiement",
    "description": "Série d'articles sur la création d'un SaaS de A à Z",
    "url": "https://krismos.fr/blog/",
    "author": {
      "@type": "Person",
      "name": "Christophe Mostefaoui",
      "url": "https://krismos.fr/"
    },
    "about": {
      "@type": "Organization",
      "name": "SmartPlanning",
      "url": "https://smartplanning.fr/",
      "sameAs": [
        "https://www.linkedin.com/company/smartplanning-fr/",
        "https://www.youtube.com/@SmartPlanning-x2c"
      ]
    },
    "blogPost": posts.map((post) => ({
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.date.toISOString(),
      "url": `https://krismos.fr/blog/${post.slug}/`
    }))
  })} />

  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Portfolio", "item": "https://krismos.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://krismos.fr/blog/" }
    ]
  })} />

  <main id="main-content" class="blog-index">
    <header class="blog-header">
      <span class="blog-label">Blog technique</span>
      <h1 class="blog-title-seo">SmartPlanning — Du concept au déploiement</h1>
      <div class="blog-hero">
        <img
          src="/images/blog/smartplanning-conception.png"
          alt="Christophe Mostefaoui — SmartPlanning, du concept au déploiement"
          class="blog-hero-img"
          width="900"
          height="500"
          loading="eager"
        />
      </div>
      <p class="blog-description">
        Chaque étape de la création d'un SaaS de gestion d'équipes : analyse des besoins,
        architecture, développement, tests et mise en production.
        Code, décisions et leçons apprises.
      </p>

      <div class="blog-follow" role="group" aria-label="Accéder à SmartPlanning et le suivre sur les réseaux">
        <a
          href="https://smartplanning.fr/"
          target="_blank"
          rel="noopener noreferrer"
          class="blog-visit-btn"
          aria-label="Accéder au site officiel SmartPlanning"
          title="smartplanning.fr — Site officiel du SaaS"
        >
          <span class="blog-visit-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </span>
          <span class="blog-visit-content">
            <span class="blog-visit-label">Voir le site officiel</span>
            <span class="blog-visit-url">smartplanning.fr</span>
          </span>
          <svg class="blog-visit-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>

        <div class="blog-follow-divider" aria-hidden="true"></div>

        <div class="blog-follow-social">
          <span class="blog-follow-label">
            <span class="blog-follow-dot" aria-hidden="true"></span>
            Suivez SmartPlanning
          </span>
          <div class="blog-follow-pills">
            <a
              href="https://www.linkedin.com/company/smartplanning-fr/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill social-pill-linkedin"
              aria-label="Page LinkedIn officielle de SmartPlanning"
              title="LinkedIn — Actualités, retours d'expérience, levée de fonds"
            >
              <span class="social-pill-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.852 3.37-1.852 3.601 0 4.267 2.37 4.267 5.455v6.288zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </span>
              <span class="social-pill-label">LinkedIn</span>
            </a>
            <a
              href="https://www.youtube.com/@SmartPlanning-x2c"
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill social-pill-youtube"
              aria-label="Chaîne YouTube officielle de SmartPlanning"
              title="YouTube — Démos, tutos et coulisses du SaaS"
            >
              <span class="social-pill-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </span>
              <span class="social-pill-label">YouTube</span>
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Filtres catégories -->
    <div class="filters" role="tablist" aria-label="Filtrer par catégorie">
      {categories.map((cat) => (
        <button
          role="tab"
          class={`filter-btn ${cat.key === 'all' ? 'active' : ''}`}
          data-category={cat.key}
          aria-selected={cat.key === 'all' ? 'true' : 'false'}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Timeline d'articles -->
    <div class="posts-timeline">
      {posts.map((post) => (
        <a
          href={`/blog/${post.slug}/`}
          class="post-card"
          data-category={post.data.category}
        >
          <div class="post-step" style={`--step-color: ${categoryColors[post.data.category] || 'var(--accent)'}`}>
            {String(post.data.order).padStart(2, '0')}
          </div>
          <div class="post-content">
            <div class="post-meta">
              <span class="post-category" style={`color: ${categoryColors[post.data.category] || 'var(--accent)'}`}>
                {categoryLabels[post.data.category] || post.data.category}
              </span>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-description">{post.data.description}</p>
            <div class="post-tags">
              {post.data.tags.slice(0, 4).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
          {post.data.image && (
            <img src={post.data.image} alt="" class="post-image" loading="lazy" />
          )}
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="empty-state">
        <p>Les articles arrivent bientôt.</p>
      </div>
    )}
  </main>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const postCards = document.querySelectorAll<HTMLElement>('.post-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      filterBtns.forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      postCards.forEach((card) => {
        if (category === 'all' || card.dataset.category === category) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

</script>

<style>
  /* === Header === */
  .blog-index {
    padding-top: calc(var(--nav-height) + 2rem);
    max-width: 900px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-bottom: 4rem;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog-title-seo {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  /* === Hero image === */
  .blog-hero {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
  }

  .blog-hero-img {
    width: 100%;
    height: auto;
    aspect-ratio: 9 / 5;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .blog-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.75rem;
    display: block;
  }

  .blog-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* === Follow SmartPlanning === */
  .blog-follow {
    margin-top: 2rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
    background: linear-gradient(
      135deg,
      rgba(59, 130, 246, 0.08) 0%,
      rgba(24, 24, 27, 0.6) 50%,
      rgba(168, 85, 247, 0.06) 100%
    );
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  /* CTA principal : site officiel */
  .blog-visit-btn {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1.125rem;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 50%, #1d4ed8 100%);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius);
    text-decoration: none;
    box-shadow:
      0 6px 20px rgba(59, 130, 246, 0.35),
      0 0 0 1px rgba(59, 130, 246, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
    overflow: hidden;
    isolation: isolate;
  }

  .blog-visit-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 30%,
      rgba(255, 255, 255, 0.18) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    animation: visit-shimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes visit-shimmer {
    0%, 60% { transform: translateX(-100%); }
    80%     { transform: translateX(100%); }
    100%    { transform: translateX(100%); }
  }

  .blog-visit-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
    color: #ffffff;
    box-shadow:
      0 10px 28px rgba(59, 130, 246, 0.55),
      0 0 0 1px rgba(59, 130, 246, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .blog-visit-btn:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
  }

  .blog-visit-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    color: #ffffff;
    flex-shrink: 0;
  }

  .blog-visit-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .blog-visit-label {
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .blog-visit-url {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
  }

  .blog-visit-arrow {
    flex-shrink: 0;
    opacity: 0.85;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .blog-visit-btn:hover .blog-visit-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  /* Séparateur subtil */
  .blog-follow-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--border) 20%,
      var(--border) 80%,
      transparent 100%
    );
  }

  .blog-follow-social {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .blog-follow-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.01em;
  }

  .blog-follow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.18), 0 0 10px rgba(34, 197, 94, 0.6);
    animation: follow-pulse 1.8s ease-in-out infinite;
  }

  @keyframes follow-pulse {
    0%, 100% { transform: scale(1);    opacity: 1; }
    50%      { transform: scale(1.25); opacity: 0.75; }
  }

  .blog-follow-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* === Social pills (LinkedIn / YouTube) === */
  .social-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.875rem 0.45rem 0.55rem;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
    overflow: visible;
  }

  .social-pill::before {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 9999px;
    opacity: 0.55;
    z-index: -1;
    filter: blur(8px);
    animation: social-glow 2.8s ease-in-out infinite;
  }

  @keyframes social-glow {
    0%, 100% { opacity: 0.4; transform: scale(0.96); }
    50%      { opacity: 0.8; transform: scale(1.05); }
  }

  .social-pill:hover {
    transform: translateY(-2px) scale(1.03);
    filter: brightness(1.08);
    color: #ffffff;
  }

  .social-pill:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
  }

  .social-pill-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
  }

  .social-pill-label {
    line-height: 1;
  }

  /* LinkedIn variant */
  .social-pill-linkedin {
    background: linear-gradient(135deg, #0a66c2 0%, #0958a8 100%);
    box-shadow:
      0 4px 14px rgba(10, 102, 194, 0.35),
      0 0 0 1px rgba(10, 102, 194, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }
  .social-pill-linkedin::before {
    background: radial-gradient(circle, rgba(10, 102, 194, 0.45) 0%, transparent 70%);
  }
  .social-pill-linkedin:hover {
    box-shadow:
      0 8px 24px rgba(10, 102, 194, 0.55),
      0 0 0 1px rgba(10, 102, 194, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  /* YouTube variant */
  .social-pill-youtube {
    background: linear-gradient(135deg, #ff0000 0%, #cc0000 100%);
    box-shadow:
      0 4px 14px rgba(255, 0, 0, 0.35),
      0 0 0 1px rgba(255, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }
  .social-pill-youtube::before {
    background: radial-gradient(circle, rgba(255, 0, 0, 0.45) 0%, transparent 70%);
    animation-delay: 0.7s;
  }
  .social-pill-youtube:hover {
    box-shadow:
      0 8px 24px rgba(255, 0, 0, 0.55),
      0 0 0 1px rgba(255, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-follow-dot,
    .social-pill::before,
    .blog-visit-btn::before {
      animation: none;
    }
  }

  /* === Filters === */
  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.4rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition);
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--border-light);
    color: var(--text);
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  /* === Posts Timeline === */
  .posts-timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background var(--transition), transform var(--transition);
    align-items: flex-start;
  }

  .post-card:hover {
    border-color: var(--border-light);
    background: var(--bg-card-hover);
    transform: translateY(-1px);
    color: inherit;
  }

  .post-step {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--step-color);
    background: color-mix(in srgb, var(--step-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--step-color) 20%, transparent);
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .post-category {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .post-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
  }

  .post-image {
    width: 140px;
    height: 90px;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
    }

    .post-step {
      width: 36px;
      height: 36px;
      font-size: 0.75rem;
    }

    .post-image {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
    }
  }
</style>
