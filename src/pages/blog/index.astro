---
import Layout from '../../layouts/Layout.astro';
import BlogNav from '../../components/BlogNav.astro';
import { getCollection } from 'astro:content';
import { categoryColors, categoryLabels } from '../../data/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { key: 'all', label: 'Tout' },
  { key: 'analyse', label: 'Analyse' },
  { key: 'gestion-projet', label: 'Gestion' },
  { key: 'conception', label: 'Conception' },
  { key: 'developpement', label: 'Dev' },
  { key: 'tests', label: 'Tests' },
  { key: 'deploiement', label: 'Déploiement' },
  { key: 'demo', label: 'Démos' },
];
---

<Layout
  title="Blog SmartPlanning — Du concept au déploiement | Christophe Mostefaoui"
  description="Série d'articles détaillant la création de SmartPlanning, SaaS de gestion d'équipes : analyse des besoins, conception, développement Next.js, CI/CD Docker et déploiement VPS."
  url="https://krismos.fr/blog/"
>
  <BlogNav activeLink="blog" />

  <!-- JSON-LD Blog -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "SmartPlanning — Du concept au déploiement",
    "description": "Série d'articles sur la création d'un SaaS de A à Z",
    "url": "https://krismos.fr/blog/",
    "author": {
      "@type": "Person",
      "name": "Christophe Mostefaoui",
      "url": "https://krismos.fr/"
    },
    "blogPost": posts.map((post) => ({
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.date.toISOString(),
      "url": `https://krismos.fr/blog/${post.slug}/`
    }))
  })} />

  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Portfolio", "item": "https://krismos.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://krismos.fr/blog/" }
    ]
  })} />

  <main id="main-content" class="blog-index">
    <header class="blog-header">
      <span class="blog-label">Blog technique</span>
      <h1 class="blog-title">SmartPlanning</h1>
      <p class="blog-subtitle">Du concept au déploiement</p>
      <p class="blog-description">
        Chaque étape de la création d'un SaaS de gestion d'équipes — analyse des besoins,
        architecture, développement, tests et mise en production.
        Code, décisions et leçons apprises.
      </p>
    </header>

    <!-- Filtres catégories -->
    <div class="filters" role="tablist" aria-label="Filtrer par catégorie">
      {categories.map((cat) => (
        <button
          role="tab"
          class={`filter-btn ${cat.key === 'all' ? 'active' : ''}`}
          data-category={cat.key}
          aria-selected={cat.key === 'all' ? 'true' : 'false'}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Timeline d'articles -->
    <div class="posts-timeline">
      {posts.map((post) => (
        <a
          href={`/blog/${post.slug}/`}
          class="post-card"
          data-category={post.data.category}
        >
          <div class="post-step" style={`--step-color: ${categoryColors[post.data.category] || 'var(--accent)'}`}>
            {String(post.data.order).padStart(2, '0')}
          </div>
          <div class="post-content">
            <div class="post-meta">
              <span class="post-category" style={`color: ${categoryColors[post.data.category] || 'var(--accent)'}`}>
                {categoryLabels[post.data.category] || post.data.category}
              </span>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-description">{post.data.description}</p>
            <div class="post-tags">
              {post.data.tags.slice(0, 4).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
          {post.data.image && (
            <img src={post.data.image} alt="" class="post-image" loading="lazy" />
          )}
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="empty-state">
        <p>Les articles arrivent bientôt.</p>
      </div>
    )}
  </main>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const postCards = document.querySelectorAll<HTMLElement>('.post-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      filterBtns.forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      postCards.forEach((card) => {
        if (category === 'all' || card.dataset.category === category) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

</script>

<style>
  /* === Header === */
  .blog-index {
    padding-top: calc(var(--nav-height) + 2rem);
    max-width: 900px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-bottom: 4rem;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.75rem;
    display: block;
  }

  .blog-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .blog-subtitle {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .blog-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* === Filters === */
  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.4rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition);
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--border-light);
    color: var(--text);
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  /* === Posts Timeline === */
  .posts-timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background var(--transition), transform var(--transition);
    align-items: flex-start;
  }

  .post-card:hover {
    border-color: var(--border-light);
    background: var(--bg-card-hover);
    transform: translateY(-1px);
    color: inherit;
  }

  .post-step {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--step-color);
    background: color-mix(in srgb, var(--step-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--step-color) 20%, transparent);
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .post-category {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .post-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
  }

  .post-image {
    width: 140px;
    height: 90px;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
    }

    .post-step {
      width: 36px;
      height: 36px;
      font-size: 0.75rem;
    }

    .post-image {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
    }
  }
</style>
